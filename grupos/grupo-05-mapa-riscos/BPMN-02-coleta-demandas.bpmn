<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="BPMN-02-coleta-demandas" targetNamespace="http://g05.facape.br/coleta-demandas" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_Coleta">
    <participant id="Pool_Coleta" name="FACAPE — Sub-processo: Coleta e Consolidação de Demandas" processRef="Proc_Coleta" />
  </collaboration>
  <process id="Proc_Coleta" isExecutable="false">
    <laneSet id="LS_Coleta">
      <lane id="Lane_Almoxarifado" name="Almoxarifado">
        <flowNodeRef>End_DFDGerado</flowNodeRef>
        <flowNodeRef>Task_ExcluirItemEstoque</flowNodeRef>
        <flowNodeRef>Task_RegistrarItem</flowNodeRef>
        <flowNodeRef>Task_GerarDFDFinal</flowNodeRef>
        <flowNodeRef>Task_ReceberDemanda</flowNodeRef>
        <flowNodeRef>GW_ItemEstoque</flowNodeRef>
        <flowNodeRef>Task_ConsolidarDFD</flowNodeRef>
        <flowNodeRef>Task_SolicitarCorrecao</flowNodeRef>
        <flowNodeRef>GW_DemandaValida</flowNodeRef>
      </lane>
      <lane id="Lane_Secretarias" name="Secretarias">
        <flowNodeRef>Task_ReceberNotificacao</flowNodeRef>
        <flowNodeRef>Task_NotificarNaoResposta</flowNodeRef>
        <flowNodeRef>GW_SecretariaRespondeu</flowNodeRef>
        <flowNodeRef>Task_PreencherDemanda</flowNodeRef>
        <flowNodeRef>Task_SubmeterDemanda</flowNodeRef>
      </lane>
      <lane id="Lane_Gestor" name="Gestor do PCA">
        <flowNodeRef>Start_InicioColeta</flowNodeRef>
        <flowNodeRef>Task_AbrirPeriodoColeta</flowNodeRef>
        <flowNodeRef>Task_NotificarSecretarias</flowNodeRef>
        <flowNodeRef>Task_EncerrarColeta</flowNodeRef>
        <flowNodeRef>GW_PrazoAtingido</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_InicioColeta" name="Inicio do periodo de planejamento anual">
      <outgoing>F01</outgoing>
    </startEvent>
    <endEvent id="End_DFDGerado" name="DFD gerado e encaminhado ao Setor de Compras">
      <incoming>F_DFDok</incoming>
    </endEvent>
    <userTask id="Task_AbrirPeriodoColeta" name="Abrir periodo de coleta de demandas">
      <incoming>F01</incoming>
      <outgoing>F02</outgoing>
    </userTask>
    <serviceTask id="Task_NotificarSecretarias" name="Notificar secretarias sobre prazo de envio de demandas">
      <incoming>F02</incoming>
      <outgoing>F03</outgoing>
    </serviceTask>
    <userTask id="Task_ExcluirItemEstoque" name="Excluir item da demanda (atendido pelo estoque)">
      <incoming>F_EstoqueSim</incoming>
      <outgoing>F_VoltaConsolidar</outgoing>
    </userTask>
    <userTask id="Task_RegistrarItem" name="Registrar item na lista de demandas consolidadas">
      <incoming>F_EstoqueNao</incoming>
      <outgoing>F07</outgoing>
    </userTask>
    <userTask id="Task_GerarDFDFinal" name="Gerar DFD final e encaminhar ao Setor de Compras">
      <incoming>F_ValidaSim</incoming>
      <incoming>F_CorrecaoOk</incoming>
      <outgoing>F_DFDok</outgoing>
    </userTask>
    <userTask id="Task_EncerrarColeta" name="Encerrar periodo de coleta compulsoriamente">
      <incoming>F_PrazoSim</incoming>
      <incoming>F_SubmissaoOk</incoming>
      <outgoing>F_Encerrar</outgoing>
      <outgoing>Flow_0ezt64k</outgoing>
    </userTask>
    <exclusiveGateway id="GW_PrazoAtingido" name="Prazo de coleta atingido?">
      <incoming>F03</incoming>
      <incoming>Flow_0ezt64k</incoming>
      <outgoing>F_PrazoSim</outgoing>
      <outgoing>F_PrazoNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_ReceberNotificacao" name="Receber notificacao de abertura do periodo">
      <incoming>F_PrazoNao</incoming>
      <outgoing>F04</outgoing>
    </userTask>
    <serviceTask id="Task_NotificarNaoResposta" name="Notificar gestores sobre secretaria sem resposta">
      <incoming>F_RespondeuNao</incoming>
      <outgoing>F_VoltaPrazo</outgoing>
    </serviceTask>
    <exclusiveGateway id="GW_SecretariaRespondeu" name="Secretaria respondeu no prazo?">
      <incoming>F04</incoming>
      <outgoing>F_RespondeuSim</outgoing>
      <outgoing>F_RespondeuNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_PreencherDemanda" name="Preencher formulario de demanda (tipo, quantidade, justificativa)">
      <incoming>F_RespondeuSim</incoming>
      <outgoing>F05</outgoing>
    </userTask>
    <userTask id="Task_SubmeterDemanda" name="Submeter demanda ao Almoxarifado">
      <incoming>F05</incoming>
      <outgoing>F_SubmissaoOk</outgoing>
    </userTask>
    <userTask id="Task_ReceberDemanda" name="Receber e registrar demanda da secretaria">
      <incoming>F_Encerrar</incoming>
      <outgoing>F06</outgoing>
    </userTask>
    <exclusiveGateway id="GW_ItemEstoque" name="Item ja disponivel em estoque?">
      <incoming>F06</incoming>
      <outgoing>F_EstoqueSim</outgoing>
      <outgoing>F_EstoqueNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_ConsolidarDFD" name="Consolidar todas as demandas no DFD">
      <incoming>F07</incoming>
      <incoming>F_VoltaConsolidar</incoming>
      <outgoing>F08</outgoing>
    </userTask>
    <userTask id="Task_SolicitarCorrecao" name="Solicitar correcao a secretaria (fracionamento ou dado incorreto)">
      <incoming>F_ValidaNao</incoming>
      <outgoing>F_CorrecaoOk</outgoing>
    </userTask>
    <exclusiveGateway id="GW_DemandaValida" name="Demanda valida e sem fracionamento indevido?">
      <incoming>F08</incoming>
      <outgoing>F_ValidaSim</outgoing>
      <outgoing>F_ValidaNao</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="F01" sourceRef="Start_InicioColeta" targetRef="Task_AbrirPeriodoColeta" />
    <sequenceFlow id="F_DFDok" sourceRef="Task_GerarDFDFinal" targetRef="End_DFDGerado" />
    <sequenceFlow id="F02" sourceRef="Task_AbrirPeriodoColeta" targetRef="Task_NotificarSecretarias" />
    <sequenceFlow id="F03" sourceRef="Task_NotificarSecretarias" targetRef="GW_PrazoAtingido" />
    <sequenceFlow id="F_EstoqueSim" name="Sim — excluir da demanda" sourceRef="GW_ItemEstoque" targetRef="Task_ExcluirItemEstoque" />
    <sequenceFlow id="F_VoltaConsolidar" sourceRef="Task_ExcluirItemEstoque" targetRef="Task_ConsolidarDFD" />
    <sequenceFlow id="F_EstoqueNao" name="Nao — incluir no DFD" sourceRef="GW_ItemEstoque" targetRef="Task_RegistrarItem" />
    <sequenceFlow id="F07" sourceRef="Task_RegistrarItem" targetRef="Task_ConsolidarDFD" />
    <sequenceFlow id="F_ValidaSim" name="Sim — DFD aprovado" sourceRef="GW_DemandaValida" targetRef="Task_GerarDFDFinal" />
    <sequenceFlow id="F_CorrecaoOk" sourceRef="Task_SolicitarCorrecao" targetRef="Task_GerarDFDFinal" />
    <sequenceFlow id="F_PrazoSim" name="Sim — prazo encerrado" sourceRef="GW_PrazoAtingido" targetRef="Task_EncerrarColeta" />
    <sequenceFlow id="F_SubmissaoOk" sourceRef="Task_SubmeterDemanda" targetRef="Task_EncerrarColeta" />
    <sequenceFlow id="F_Encerrar" sourceRef="Task_EncerrarColeta" targetRef="Task_ReceberDemanda" />
    <sequenceFlow id="Flow_0ezt64k" sourceRef="Task_EncerrarColeta" targetRef="GW_PrazoAtingido" />
    <sequenceFlow id="F_VoltaPrazo" sourceRef="Task_NotificarNaoResposta" targetRef="GW_PrazoAtingido" />
    <sequenceFlow id="F_PrazoNao" name="Nao — aguardando respostas" sourceRef="GW_PrazoAtingido" targetRef="Task_ReceberNotificacao" />
    <sequenceFlow id="F04" sourceRef="Task_ReceberNotificacao" targetRef="GW_SecretariaRespondeu" />
    <sequenceFlow id="F_RespondeuNao" name="Nao — sem resposta" sourceRef="GW_SecretariaRespondeu" targetRef="Task_NotificarNaoResposta" />
    <sequenceFlow id="F_RespondeuSim" name="Sim" sourceRef="GW_SecretariaRespondeu" targetRef="Task_PreencherDemanda" />
    <sequenceFlow id="F05" sourceRef="Task_PreencherDemanda" targetRef="Task_SubmeterDemanda" />
    <sequenceFlow id="F06" sourceRef="Task_ReceberDemanda" targetRef="GW_ItemEstoque" />
    <sequenceFlow id="F08" sourceRef="Task_ConsolidarDFD" targetRef="GW_DemandaValida" />
    <sequenceFlow id="F_ValidaNao" name="Nao — corrigir" sourceRef="GW_DemandaValida" targetRef="Task_SolicitarCorrecao" />
  </process>
  <bpmndi:BPMNDiagram id="Diag_02">
    <bpmndi:BPMNPlane id="Plane_02" bpmnElement="Collab_Coleta">
