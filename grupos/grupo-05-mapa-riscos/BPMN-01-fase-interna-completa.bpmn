<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="BPMN-01-fase-interna-completa" targetNamespace="http://g05.facape.br/fase-interna" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_FaseInterna">
    <participant id="Pool_FACAPE" name="FACAPE — Fase Interna do Processo Licitatório" processRef="Proc_FaseInterna" />
    <participant id="Pool_Prefeitura" name="Prefeitura de Petrolina (Externo)" processRef="Proc_Prefeitura" />
    <messageFlow id="MF_EnvioPrefeitura" sourceRef="Task_EnviarPrefeitura" targetRef="Start_Prefeitura" />
  </collaboration>
  <process id="Proc_FaseInterna" isExecutable="false">
    <laneSet id="LS_Interno">
      <lane id="Lane_Juridico" name="Jurídico Interno">
        <flowNodeRef>Task_ValidarDocumentacao</flowNodeRef>
        <flowNodeRef>End_ProcessoAutuado</flowNodeRef>
        <flowNodeRef>Task_EnviarPrefeitura</flowNodeRef>
        <flowNodeRef>GW_DocumentacaoCompleta</flowNodeRef>
        <flowNodeRef>Task_CorrigirDocumentacao</flowNodeRef>
      </lane>
      <lane id="Lane_Licitacoes" name="Setor de Licitações">
        <flowNodeRef>End_Dispensa</flowNodeRef>
        <flowNodeRef>Task_ConsultarPNCP</flowNodeRef>
        <flowNodeRef>Task_ElaborarTR</flowNodeRef>
      </lane>
      <lane id="Lane_Compras" name="Setor de Compras">
        <flowNodeRef>GW_ValorDispensa</flowNodeRef>
        <flowNodeRef>Task_ElaborarETP</flowNodeRef>
        <flowNodeRef>Task_ConsultarBancoPrecos</flowNodeRef>
        <flowNodeRef>Task_ElaborarMapaRiscos</flowNodeRef>
        <flowNodeRef>GW_MEEPP</flowNodeRef>
      </lane>
      <lane id="Lane_Almoxarifado" name="Almoxarifado">
        <flowNodeRef>Task_ConsolidarDemandas</flowNodeRef>
        <flowNodeRef>Task_GerarDFD</flowNodeRef>
      </lane>
      <lane id="Lane_Secretaria" name="Secretaria / Colegiado">
        <flowNodeRef>Start_Necessidade</flowNodeRef>
        <flowNodeRef>Task_RegistrarDemanda</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_Necessidade" name="Necessidade de compra identificada">
      <outgoing>F01</outgoing>
    </startEvent>
    <userTask id="Task_RegistrarDemanda" name="Registrar demanda de material ou servico">
      <incoming>F01</incoming>
      <outgoing>F02</outgoing>
    </userTask>
    <userTask id="Task_ConsolidarDemandas" name="Consolidar demandas das secretarias e verificar estoque">
      <incoming>F02</incoming>
      <outgoing>F03</outgoing>
    </userTask>
    <userTask id="Task_GerarDFD" name="Gerar Documento de Formalizacao da Demanda (DFD)">
      <incoming>F03</incoming>
      <outgoing>F04</outgoing>
    </userTask>
    <exclusiveGateway id="GW_ValorDispensa" name="Valor estimado igual ou menor que R$ 57.000?">
      <incoming>F04</incoming>
      <outgoing>F_SimDispensa</outgoing>
      <outgoing>F_NaoDispensa</outgoing>
    </exclusiveGateway>
    <endEvent id="End_Dispensa" name="Contratacao por dispensa concluida">
      <incoming>F_Dispensa</incoming>
    </endEvent>
    <userTask id="Task_Dispensa" name="Realizar contratacao por dispensa de licitacao">
      <incoming>F_SimDispensa</incoming>
      <outgoing>F_Dispensa</outgoing>
    </userTask>
    <userTask id="Task_ElaborarETP" name="Elaborar Estudo Tecnico Preliminar (ETP)">
      <incoming>F_NaoDispensa</incoming>
      <outgoing>F05</outgoing>
    </userTask>
    <serviceTask id="Task_ConsultarBancoPrecos" name="Consultar Banco de Precos gov.br (minimo 3 fornecedores)">
      <incoming>F05</incoming>
      <outgoing>F06</outgoing>
    </serviceTask>
    <userTask id="Task_ElaborarMapaRiscos" name="Elaborar Mapa de Riscos do produto (G05)">
      <incoming>F06</incoming>
      <outgoing>F07</outgoing>
    </userTask>
    <exclusiveGateway id="GW_MEEPP" name="Processo exclusivo ME/EPP ou ampla concorrencia?">
      <incoming>F07</incoming>
      <outgoing>F_NaoMEEPP</outgoing>
      <outgoing>F_SimMEEPP</outgoing>
    </exclusiveGateway>
    <userTask id="Task_ValidarDocumentacao" name="Validar documentacao: DFD, ETP, Mapa de Riscos e TR">
      <incoming>F10</incoming>
      <incoming>F_Corrigido</incoming>
      <outgoing>F11</outgoing>
    </userTask>
    <userTask id="Task_AplicarCotaMEEPP" name="Aplicar cota exclusiva ou reservada para ME/EPP (Lei 123/2006)">
      <incoming>F_SimMEEPP</incoming>
      <outgoing>F08</outgoing>
    </userTask>
    <serviceTask id="Task_ConsultarPNCP" name="Consultar PNCP — Portal Nacional de Compras Publicas">
      <incoming>F09</incoming>
      <outgoing>F10</outgoing>
    </serviceTask>
    <endEvent id="End_ProcessoAutuado" name="Processo autuado na Prefeitura" />
    <userTask id="Task_EnviarPrefeitura" name="Enviar processo para a Prefeitura via sistema 1doc">
      <incoming>F_DocOk</incoming>
    </userTask>
    <exclusiveGateway id="GW_DocumentacaoCompleta" name="Documentacao completa e conforme?">
      <incoming>F11</incoming>
      <outgoing>F_DocOk</outgoing>
      <outgoing>F_DocIncompleta</outgoing>
    </exclusiveGateway>
    <userTask id="Task_CorrigirDocumentacao" name="Solicitar correcoes ao setor responsavel">
      <incoming>F_DocIncompleta</incoming>
      <outgoing>F_Corrigido</outgoing>
    </userTask>
    <userTask id="Task_ElaborarTR" name="Elaborar Termo de Referencia (TR)">
      <incoming>F08</incoming>
      <incoming>F_NaoMEEPP</incoming>
      <outgoing>F09</outgoing>
    </userTask>
    <sequenceFlow id="F01" sourceRef="Start_Necessidade" targetRef="Task_RegistrarDemanda" />
    <sequenceFlow id="F02" sourceRef="Task_RegistrarDemanda" targetRef="Task_ConsolidarDemandas" />
    <sequenceFlow id="F03" sourceRef="Task_ConsolidarDemandas" targetRef="Task_GerarDFD" />
    <sequenceFlow id="F04" sourceRef="Task_GerarDFD" targetRef="GW_ValorDispensa" />
    <sequenceFlow id="F_SimDispensa" name="Sim — dispensa" sourceRef="GW_ValorDispensa" targetRef="Task_Dispensa" />
    <sequenceFlow id="F_NaoDispensa" name="Nao — processo normal" sourceRef="GW_ValorDispensa" targetRef="Task_ElaborarETP" />
    <sequenceFlow id="F_Dispensa" sourceRef="Task_Dispensa" targetRef="End_Dispensa" />
    <sequenceFlow id="F05" sourceRef="Task_ElaborarETP" targetRef="Task_ConsultarBancoPrecos" />
    <sequenceFlow id="F06" sourceRef="Task_ConsultarBancoPrecos" targetRef="Task_ElaborarMapaRiscos" />
    <sequenceFlow id="F07" sourceRef="Task_ElaborarMapaRiscos" targetRef="GW_MEEPP" />
    <sequenceFlow id="F_NaoMEEPP" name="Ampla concorrencia" sourceRef="GW_MEEPP" targetRef="Task_ElaborarTR" />
    <sequenceFlow id="F_SimMEEPP" name="Exclusivo ME/EPP" sourceRef="GW_MEEPP" targetRef="Task_AplicarCotaMEEPP" />
    <sequenceFlow id="F10" sourceRef="Task_ConsultarPNCP" targetRef="Task_ValidarDocumentacao" />
    <sequenceFlow id="F_Corrigido" sourceRef="Task_CorrigirDocumentacao" targetRef="Task_ValidarDocumentacao" />
    <sequenceFlow id="F11" sourceRef="Task_ValidarDocumentacao" targetRef="GW_DocumentacaoCompleta" />
    <sequenceFlow id="F08" sourceRef="Task_AplicarCotaMEEPP" targetRef="Task_ElaborarTR" />
    <sequenceFlow id="F09" sourceRef="Task_ElaborarTR" targetRef="Task_ConsultarPNCP" />
    <sequenceFlow id="F_DocOk" name="Sim — documentacao ok" sourceRef="GW_DocumentacaoCompleta" targetRef="Task_EnviarPrefeitura" />
    <sequenceFlow id="F_DocIncompleta" name="Nao — pendencias" sourceRef="GW_DocumentacaoCompleta" targetRef="Task_CorrigirDocumentacao" />
  </process>
  <process id="Proc_Prefeitura" isExecutable="false">
    <startEvent id="Start_Prefeitura" name="Processo recebido da FACAPE">
      <outgoing>FP01</outgoing>
      <messageEventDefinition />
    </startEvent>
    <endEvent id="End_Prefeitura" name="Pregao realizado e resultado publicado">
      <incoming>FP01</incoming>
    </endEvent>
    <sequenceFlow id="FP01" sourceRef="Start_Prefeitura" targetRef="End_Prefeitura" />
  </process>
  <bpmndi:BPMNDiagram id="Diag_01">
    <bpmndi:BPMNPlane id="Plane_01" bpmnElement="Collab_FaseInterna">
      <bpmndi:BPMNShape id="Pool_FACAPE_Shape" bpmnElement="Pool_FACAPE" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2090" height="980" />
