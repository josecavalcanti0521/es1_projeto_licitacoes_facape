<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="BPMN-G05-mapa-riscos" targetNamespace="http://g05.facape.br/mapa-riscos" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_G05">
    <participant id="Pool_G05" name="Modulo G05 — Mapa de Riscos | FACAPE" processRef="Proc_G05" />
  </collaboration>
  <process id="Proc_G05" isExecutable="false">
    <laneSet id="LS_G05">
      <lane id="Lane_CC" name="Chefe de Compras">
        <flowNodeRef>End_Aprovado</flowNodeRef>
        <flowNodeRef>Task_RegistrarRejeicao</flowNodeRef>
        <flowNodeRef>Task_AprovarMapa</flowNodeRef>
        <flowNodeRef>GW_DecisaoFinal</flowNodeRef>
      </lane>
      <lane id="Lane_JI" name="Juridico Interno">
        <flowNodeRef>Task_ValidarJuridico</flowNodeRef>
        <flowNodeRef>Task_RegistrarParecerNeg</flowNodeRef>
        <flowNodeRef>GW_PareceJuridico</flowNodeRef>
        <flowNodeRef>End_Revisao</flowNodeRef>
      </lane>
      <lane id="Lane_Sys" name="Sistema (automatico)">
        <flowNodeRef>Task_CalcularScore</flowNodeRef>
        <flowNodeRef>Task_ClassificarNivel</flowNodeRef>
        <flowNodeRef>GW_ScoreCritico</flowNodeRef>
        <flowNodeRef>Task_AlertarCritico</flowNodeRef>
        <flowNodeRef>Task_ValidarCompletude</flowNodeRef>
        <flowNodeRef>GW_MapaCompleto</flowNodeRef>
        <flowNodeRef>Task_GerarMapa</flowNodeRef>
      </lane>
      <lane id="Lane_CL" name="Chefe de Licitacoes">
        <flowNodeRef>Start_TR</flowNodeRef>
        <flowNodeRef>Task_AnalisarTR</flowNodeRef>
        <flowNodeRef>Task_IdentificarRisco</flowNodeRef>
        <flowNodeRef>Task_CategorizarRisco</flowNodeRef>
        <flowNodeRef>Task_InformarPI</flowNodeRef>
        <flowNodeRef>Task_DefinirMitigacao</flowNodeRef>
        <flowNodeRef>Task_CorrigirPend</flowNodeRef>
        <flowNodeRef>GW_MaisRiscos</flowNodeRef>
        <flowNodeRef>Task_SubmeterMapa</flowNodeRef>
      </lane>
    </laneSet>
    <userTask id="Task_ValidarJuridico" name="Validar riscos criticos&#10;do ponto de vista legal">
      <incoming>F_sub_jur</incoming>
      <outgoing>F_jur_dec</outgoing>
    </userTask>
    <userTask id="Task_RegistrarParecerNeg" name="Registrar parecer negativo&#10;e solicitar revisao">
      <incoming>F_jur_neg</incoming>
      <outgoing>F_fim_rev1</outgoing>
    </userTask>
    <endEvent id="End_Aprovado" name="Mapa aprovado disponivel para G06">
      <incoming>F_fim_ok</incoming>
      <incoming>F_fim_rev2</incoming>
    </endEvent>
    <userTask id="Task_RegistrarRejeicao" name="Registrar motivo da rejeicao">
      <incoming>F_rejeitar</incoming>
      <outgoing>F_fim_rev2</outgoing>
      <outgoing>Flow_07xhsxk</outgoing>
    </userTask>
    <userTask id="Task_AprovarMapa" name="Revisar e aprovar Mapa de Riscos">
      <incoming>Flow_0wl5k3o</incoming>
      <outgoing>F_dec</outgoing>
    </userTask>
    <exclusiveGateway id="GW_DecisaoFinal" name="Decisao final?">
      <incoming>F_dec</incoming>
      <outgoing>F_fim_ok</outgoing>
      <outgoing>F_rejeitar</outgoing>
      <outgoing>Flow_0wl5k3o</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="GW_PareceJuridico" name="Parecer juridico?">
      <incoming>F_jur_dec</incoming>
      <outgoing>F_jur_neg</outgoing>
      <outgoing>F_jur_ok</outgoing>
    </exclusiveGateway>
    <startEvent id="Start_TR" name="TR recebido do G04">
      <outgoing>F01</outgoing>
    </startEvent>
    <userTask id="Task_AnalisarTR" name="Analisar Termo de Referencia">
      <incoming>F01</incoming>
      <outgoing>F02</outgoing>
    </userTask>
    <userTask id="Task_IdentificarRisco" name="Identificar risco do produto&#10;(preco, especificacao, ambiente,&#10;mercado ou manutencao)">
      <incoming>F02</incoming>
      <incoming>F_corrig</incoming>
      <incoming>F_loop</incoming>
      <outgoing>F03</outgoing>
    </userTask>
    <userTask id="Task_CategorizarRisco" name="Categorizar risco&#10;(Legal, Tecnico, Mercado,&#10;Operacional, Financeiro)">
      <incoming>F03</incoming>
      <outgoing>F04</outgoing>
    </userTask>
    <userTask id="Task_InformarPI" name="Informar probabilidade (1-5)&#10;e impacto (1-5)">
      <incoming>F04</incoming>
      <outgoing>F05</outgoing>
    </userTask>
    <userTask id="Task_DefinirMitigacao" name="Definir mitigacao&#10;(Preventiva, Contingencial,&#10;Transferencia ou Aceitacao)">
      <incoming>F_score_nao</incoming>
      <incoming>Flow_1lxh27d</incoming>
      <outgoing>F09</outgoing>
    </userTask>
    <userTask id="Task_CorrigirPend" name="Corrigir riscos sem mitigacao">
      <incoming>F_incompleto</incoming>
      <outgoing>F_corrig</outgoing>
    </userTask>
    <exclusiveGateway id="GW_MaisRiscos" name="Ha mais riscos?">
      <incoming>F09</incoming>
      <incoming>F_alerta_ok</incoming>
      <outgoing>F_loop</outgoing>
      <outgoing>F10</outgoing>
      <outgoing>Flow_1lxh27d</outgoing>
    </exclusiveGateway>
    <serviceTask id="Task_CalcularScore" name="Calcular score&#10;(probabilidade x impacto)">
      <incoming>F05</incoming>
      <outgoing>F06</outgoing>
    </serviceTask>
    <serviceTask id="Task_ClassificarNivel" name="Classificar nivel do risco&#10;(Baixo / Medio / Alto / Critico)">
      <incoming>F06</incoming>
      <outgoing>F07</outgoing>
    </serviceTask>
    <exclusiveGateway id="GW_ScoreCritico" name="Score maior ou igual a 15?">
      <incoming>F07</incoming>
      <outgoing>F_score_sim</outgoing>
      <outgoing>F_score_nao</outgoing>
    </exclusiveGateway>
    <serviceTask id="Task_AlertarCritico" name="Alertar: risco critico&#10;exige validacao juridica (RN-MR-03)">
      <incoming>F_score_sim</incoming>
      <outgoing>F_alerta_ok</outgoing>
    </serviceTask>
    <serviceTask id="Task_ValidarCompletude" name="Validar completude do mapa&#10;(todo risco tem mitigacao?)">
      <incoming>F10</incoming>
      <outgoing>F11</outgoing>
    </serviceTask>
    <exclusiveGateway id="GW_MapaCompleto" name="Mapa completo?">
      <incoming>F11</incoming>
      <outgoing>F_completo</outgoing>
      <outgoing>F_incompleto</outgoing>
    </exclusiveGateway>
    <userTask id="Task_SubmeterMapa" name="Submeter mapa para aprovacao">
      <incoming>F_gerar_sub</incoming>
      <outgoing>F_sub_jur</outgoing>
    </userTask>
    <serviceTask id="Task_GerarMapa" name="Gerar Mapa de Riscos&#10;e notificar Chefe de Compras">
      <incoming>F_completo</incoming>
      <outgoing>F_gerar_sub</outgoing>
    </serviceTask>
    <sequenceFlow id="F_sub_jur" sourceRef="Task_SubmeterMapa" targetRef="Task_ValidarJuridico" />
    <sequenceFlow id="F_jur_dec" sourceRef="Task_ValidarJuridico" targetRef="GW_PareceJuridico" />
    <sequenceFlow id="F_jur_neg" name="Desfavoravel" sourceRef="GW_PareceJuridico" targetRef="Task_RegistrarParecerNeg" />
    <sequenceFlow id="F_fim_rev1" sourceRef="Task_RegistrarParecerNeg" targetRef="End_Revisao" />
    <sequenceFlow id="F_fim_ok" name="Aprovar" sourceRef="GW_DecisaoFinal" targetRef="End_Aprovado" />
    <sequenceFlow id="F_fim_rev2" sourceRef="Task_RegistrarRejeicao" targetRef="End_Aprovado" />
    <sequenceFlow id="F_rejeitar" name="Rejeitar" sourceRef="GW_DecisaoFinal" targetRef="Task_RegistrarRejeicao" />
    <sequenceFlow id="Flow_0wl5k3o" sourceRef="GW_DecisaoFinal" targetRef="Task_AprovarMapa" />
    <sequenceFlow id="F_dec" sourceRef="Task_AprovarMapa" targetRef="GW_DecisaoFinal" />
    <sequenceFlow id="F_jur_ok" name="Favoravel" sourceRef="GW_PareceJuridico" targetRef="End_Revisao" />
    <sequenceFlow id="F01" sourceRef="Start_TR" targetRef="Task_AnalisarTR" />
    <sequenceFlow id="F02" sourceRef="Task_AnalisarTR" targetRef="Task_IdentificarRisco" />
    <sequenceFlow id="F_corrig" sourceRef="Task_CorrigirPend" targetRef="Task_IdentificarRisco" />
    <sequenceFlow id="F_loop" name="Sim - proximo risco" sourceRef="GW_MaisRiscos" targetRef="Task_IdentificarRisco" />
    <sequenceFlow id="F03" sourceRef="Task_IdentificarRisco" targetRef="Task_CategorizarRisco" />
    <sequenceFlow id="F04" sourceRef="Task_CategorizarRisco" targetRef="Task_InformarPI" />
    <sequenceFlow id="F05" sourceRef="Task_InformarPI" targetRef="Task_CalcularScore" />
    <sequenceFlow id="F_score_nao" name="Nao" sourceRef="GW_ScoreCritico" targetRef="Task_DefinirMitigacao" />
    <sequenceFlow id="Flow_1lxh27d" sourceRef="GW_MaisRiscos" targetRef="Task_DefinirMitigacao" />
    <sequenceFlow id="F09" sourceRef="Task_DefinirMitigacao" targetRef="GW_MaisRiscos" />
    <sequenceFlow id="F_incompleto" name="Nao - pendencias" sourceRef="GW_MapaCompleto" targetRef="Task_CorrigirPend" />
    <sequenceFlow id="F_alerta_ok" sourceRef="Task_AlertarCritico" targetRef="GW_MaisRiscos" />
    <sequenceFlow id="F10" name="Nao - todos identificados" sourceRef="GW_MaisRiscos" targetRef="Task_ValidarCompletude" />
    <sequenceFlow id="F06" sourceRef="Task_CalcularScore" targetRef="Task_ClassificarNivel" />
    <sequenceFlow id="F07" sourceRef="Task_ClassificarNivel" targetRef="GW_ScoreCritico" />
    <sequenceFlow id="F_score_sim" name="Sim - score critico" sourceRef="GW_ScoreCritico" targetRef="Task_AlertarCritico" />
    <sequenceFlow id="F11" sourceRef="Task_ValidarCompletude" targetRef="GW_MapaCompleto" />
    <sequenceFlow id="F_completo" name="Sim" sourceRef="GW_MapaCompleto" targetRef="Task_GerarMapa" />
    <sequenceFlow id="F_gerar_sub" sourceRef="Task_GerarMapa" targetRef="Task_SubmeterMapa" />
    <endEvent id="End_Revisao" name="Mapa devolvido para revisao">
      <incoming>F_fim_rev1</incoming>
      <incoming>F_jur_ok</incoming>
      <incoming>Flow_07xhsxk</incoming>
    </endEvent>
    <sequenceFlow id="Flow_07xhsxk" sourceRef="Task_RegistrarRejeicao" targetRef="End_Revisao" />
  </process>
