        <dc:Bounds x="1982" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1960" y="535" width="83" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndOk" bpmnElement="End_ProcessoConcluido">
        <dc:Bounds x="1272" y="712" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1251" y="755" width="80" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndSusp" bpmnElement="End_Suspenso">
        <dc:Bounds x="2322" y="810" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2299" y="853" width="85" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GWDot" bpmnElement="GW_DotacaoSuficiente" isMarkerVisible="true">
        <dc:Bounds x="2055" y="705" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2046" y="655" width="65" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_AlertDot" bpmnElement="Task_AlertarSemDotacao">
        <dc:Bounds x="2010" y="805" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_ResDot" bpmnElement="Task_ReservarDotacao">
        <dc:Bounds x="1760" y="690" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Empenho" bpmnElement="Task_EmitirEmpenho">
        <dc:Bounds x="1570" y="690" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Pagamento" bpmnElement="Task_EncaminharPagamento">
        <dc:Bounds x="1380" y="690" width="140" height="80" />
