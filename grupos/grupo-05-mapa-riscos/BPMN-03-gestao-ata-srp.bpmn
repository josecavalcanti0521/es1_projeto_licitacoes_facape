<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="BPMN-03-gestao-ata-srp" targetNamespace="http://g05.facape.br/gestao-ata-srp" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_AtaSRP">
    <participant id="Pool_AtaSRP" name="FACAPE — Sub-processo: Gestão de Ata SRP e Emissão de Ordem de Fornecimento" processRef="Proc_AtaSRP" />
  </collaboration>
  <process id="Proc_AtaSRP" isExecutable="false">
    <laneSet id="LS_AtaSRP">
      <lane id="Lane_Contabilidade" name="Contabilidade">
        <flowNodeRef>End_ProcessoConcluido</flowNodeRef>
        <flowNodeRef>End_Suspenso</flowNodeRef>
        <flowNodeRef>GW_DotacaoSuficiente</flowNodeRef>
        <flowNodeRef>Task_AlertarSemDotacao</flowNodeRef>
        <flowNodeRef>Task_ReservarDotacao</flowNodeRef>
        <flowNodeRef>Task_EmitirEmpenho</flowNodeRef>
        <flowNodeRef>Task_EncaminharPagamento</flowNodeRef>
        <flowNodeRef>Task_VerificarDotacao</flowNodeRef>
      </lane>
      <lane id="Lane_Compras" name="Setor de Compras">
        <flowNodeRef>Start_NecessidadeOF</flowNodeRef>
        <flowNodeRef>Timer_AtaVencimento</flowNodeRef>
        <flowNodeRef>Task_NotificarVencimento</flowNodeRef>
        <flowNodeRef>Task_ConsultarAtasVigentes</flowNodeRef>
        <flowNodeRef>GW_AtaDisponivel</flowNodeRef>
        <flowNodeRef>Task_IniciarNovoProcesso</flowNodeRef>
        <flowNodeRef>Task_VerificarSaldo</flowNodeRef>
        <flowNodeRef>GW_PrecoCompetitivo</flowNodeRef>
        <flowNodeRef>End_NovoProcesso</flowNodeRef>
        <flowNodeRef>Task_SelecionarAta</flowNodeRef>
        <flowNodeRef>Task_VerificarCompetitividade</flowNodeRef>
        <flowNodeRef>GW_SaldoDisponivel</flowNodeRef>
        <flowNodeRef>End_SaldoEsgotado</flowNodeRef>
        <flowNodeRef>Task_EnviarOFAoFornecedor</flowNodeRef>
        <flowNodeRef>Task_AcompanharEntrega</flowNodeRef>
        <flowNodeRef>Task_PreencherOF</flowNodeRef>
        <flowNodeRef>Task_ValidarOF</flowNodeRef>
        <flowNodeRef>GW_OFValida</flowNodeRef>
        <flowNodeRef>Task_CorrigirOF</flowNodeRef>
        <flowNodeRef>Task_RegistrarEntregaParcial</flowNodeRef>
        <flowNodeRef>Task_ReceberNotaFiscal</flowNodeRef>
        <flowNodeRef>GW_EntregaConforme</flowNodeRef>
        <flowNodeRef>Task_AcionarMulta</flowNodeRef>
        <flowNodeRef>Timer_EntregaExpirada</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_NecessidadeOF" name="Necessidade de emissao de Ordem de Fornecimento">
      <outgoing>F01</outgoing>
    </startEvent>
    <intermediateCatchEvent id="Timer_AtaVencimento" name="Timer: Ata proxima do vencimento (30 dias)">
      <outgoing>F_TimerVenc</outgoing>
      <timerEventDefinition>
        <timeDuration>P30D</timeDuration>
      </timerEventDefinition>
    </intermediateCatchEvent>
    <serviceTask id="Task_NotificarVencimento" name="Notificar Setor de Compras sobre vencimento da ata">
      <incoming>F_TimerVenc</incoming>
      <outgoing>F_NotifVenc</outgoing>
    </serviceTask>
    <serviceTask id="Task_ConsultarAtasVigentes" name="Consultar atas SRP vigentes para o item">
      <incoming>F01</incoming>
      <incoming>F_NotifVenc</incoming>
      <outgoing>F02</outgoing>
    </serviceTask>
    <exclusiveGateway id="GW_AtaDisponivel" name="Ha ata SRP vigente para o item?">
      <incoming>F02</incoming>
      <outgoing>F_AtaSim</outgoing>
      <outgoing>F_AtaNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_IniciarNovoProcesso" name="Iniciar novo processo licitatorio para o item">
      <incoming>F_AtaNao</incoming>
      <incoming>F_SaldoNao</incoming>
      <incoming>F_PrecoNao</incoming>
      <outgoing>F_FimNovo1</outgoing>
    </userTask>
    <userTask id="Task_VerificarSaldo" name="Verificar saldo quantitativo disponivel na ata (limite 50% — RN-08)">
      <incoming>F03</incoming>
      <outgoing>F04</outgoing>
    </userTask>
    <exclusiveGateway id="GW_PrecoCompetitivo" name="Preco da ata e competitivo?">
      <incoming>F05</incoming>
      <outgoing>F_PrecoSim</outgoing>
      <outgoing>F_PrecoNao</outgoing>
    </exclusiveGateway>
    <endEvent id="End_NovoProcesso" name="Novo processo licitatorio iniciado">
      <incoming>F_FimNovo1</incoming>
      <incoming>F_FimNovo2</incoming>
    </endEvent>
    <userTask id="Task_SelecionarAta" name="Selecionar ata SRP mais adequada (objeto, preco, fornecedor)">
      <incoming>F_AtaSim</incoming>
      <outgoing>F03</outgoing>
    </userTask>
    <userTask id="Task_VerificarCompetitividade" name="Verificar se preco da ata e competitivo vs. cotacao atual">
      <incoming>F_SaldoSim</incoming>
      <outgoing>F05</outgoing>
    </userTask>
    <exclusiveGateway id="GW_SaldoDisponivel" name="Saldo disponivel dentro do limite de 50%?">
      <incoming>F04</incoming>
      <outgoing>F_SaldoSim</outgoing>
      <outgoing>F_SaldoNao</outgoing>
    </exclusiveGateway>
    <endEvent id="End_SaldoEsgotado" name="Saldo da ata esgotado — encerramento">
      <incoming>F_FimSaldo</incoming>
    </endEvent>
    <serviceTask id="Task_EnviarOFAoFornecedor" name="Enviar OF assinada digitalmente ao fornecedor">
      <incoming>F_OFSim</incoming>
      <outgoing>F08</outgoing>
    </serviceTask>
    <userTask id="Task_AcompanharEntrega" name="Acompanhar entrega: verificar prazo, quantidade e qualidade">
      <incoming>F08</incoming>
      <incoming>F_Multa</incoming>
      <outgoing>F09</outgoing>
    </userTask>
    <userTask id="Task_PreencherOF" name="Preencher Ordem de Fornecimento (itens, quantidade, local, prazo)">
      <incoming>F_PrecoSim</incoming>
      <outgoing>F06</outgoing>
    </userTask>
    <userTask id="Task_ValidarOF" name="Validar OF: conferir dados, valores e dotacao orcamentaria">
      <incoming>F06</incoming>
      <incoming>F_CorrigidoOF</incoming>
      <outgoing>F07</outgoing>
    </userTask>
    <exclusiveGateway id="GW_OFValida" name="OF sem erros?">
      <incoming>F07</incoming>
      <outgoing>F_OFSim</outgoing>
      <outgoing>F_OFNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_CorrigirOF" name="Corrigir inconsistencias na OF">
      <incoming>F_OFNao</incoming>
      <outgoing>F_CorrigidoOF</outgoing>
    </userTask>
    <userTask id="Task_RegistrarEntregaParcial" name="Registrar entrega parcial e notificar fornecedor do saldo pendente">
      <incoming>F_EntregaParcial</incoming>
      <outgoing>F_VoltaAcomp</outgoing>
    </userTask>
    <userTask id="Task_ReceberNotaFiscal" name="Receber e conferir Nota Fiscal Eletronica">
      <incoming>F_EntregaSim</incoming>
      <outgoing>F10</outgoing>
    </userTask>
    <exclusiveGateway id="GW_EntregaConforme" name="Entrega conforme?">
      <incoming>F09</incoming>
      <outgoing>F_EntregaSim</outgoing>
      <outgoing>F_EntregaParcial</outgoing>
    </exclusiveGateway>
    <serviceTask id="Task_AcionarMulta" name="Acionar clausula de multa por atraso na entrega">
      <incoming>F_TimerEnt</incoming>
      <outgoing>F_Multa</outgoing>
    </serviceTask>
    <intermediateCatchEvent id="Timer_EntregaExpirada" name="Timer: Prazo de entrega expirado">
      <outgoing>F_TimerEnt</outgoing>
      <timerEventDefinition>
        <timeDuration>P30D</timeDuration>
      </timerEventDefinition>
    </intermediateCatchEvent>
    <endEvent id="End_ProcessoConcluido" name="OF concluida — empenho e pagamento encaminhados">
      <incoming>F_FimOk</incoming>
    </endEvent>
    <endEvent id="End_Suspenso" name="Processo suspenso — sem dotacao orcamentaria">
      <incoming>F_FimSuspenso</incoming>
    </endEvent>
    <exclusiveGateway id="GW_DotacaoSuficiente" name="Dotacao orcamentaria suficiente?">
      <incoming>F11</incoming>
      <outgoing>F_DotSim</outgoing>
      <outgoing>F_DotNao</outgoing>
    </exclusiveGateway>
    <userTask id="Task_AlertarSemDotacao" name="Alertar gestores: sem dotacao — suspender processo">
      <incoming>F_DotNao</incoming>
      <outgoing>F_FimSuspenso</outgoing>
    </userTask>
    <userTask id="Task_ReservarDotacao" name="Reservar dotacao orcamentaria (pre-empenho)">
      <incoming>F_DotSim</incoming>
      <outgoing>F12</outgoing>
    </userTask>
    <userTask id="Task_EmitirEmpenho" name="Emitir nota de empenho vinculada a OF">
      <incoming>F12</incoming>
      <outgoing>F13</outgoing>
    </userTask>
    <userTask id="Task_EncaminharPagamento" name="Encaminhar NF e empenho para pagamento ao fornecedor">
      <incoming>F13</incoming>
      <outgoing>F_FimOk</outgoing>
    </userTask>
    <userTask id="Task_VerificarDotacao" name="Verificar disponibilidade de dotacao orcamentaria">
      <incoming>F10</incoming>
      <outgoing>F11</outgoing>
    </userTask>
    <sequenceFlow id="F01" sourceRef="Start_NecessidadeOF" targetRef="Task_ConsultarAtasVigentes" />
    <sequenceFlow id="F_TimerVenc" sourceRef="Timer_AtaVencimento" targetRef="Task_NotificarVencimento" />
    <sequenceFlow id="F_NotifVenc" sourceRef="Task_NotificarVencimento" targetRef="Task_ConsultarAtasVigentes" />
    <sequenceFlow id="F02" sourceRef="Task_ConsultarAtasVigentes" targetRef="GW_AtaDisponivel" />
    <sequenceFlow id="F_AtaSim" name="Sim" sourceRef="GW_AtaDisponivel" targetRef="Task_SelecionarAta" />
    <sequenceFlow id="F_AtaNao" name="Nao — sem ata" sourceRef="GW_AtaDisponivel" targetRef="Task_IniciarNovoProcesso" />
    <sequenceFlow id="F_SaldoNao" name="Nao — acima de 50%" sourceRef="GW_SaldoDisponivel" targetRef="Task_IniciarNovoProcesso" />
    <sequenceFlow id="F_PrecoNao" name="Nao — novo processo" sourceRef="GW_PrecoCompetitivo" targetRef="Task_IniciarNovoProcesso" />
    <sequenceFlow id="F_FimNovo1" sourceRef="Task_IniciarNovoProcesso" targetRef="End_NovoProcesso" />
    <sequenceFlow id="F03" sourceRef="Task_SelecionarAta" targetRef="Task_VerificarSaldo" />
    <sequenceFlow id="F04" sourceRef="Task_VerificarSaldo" targetRef="GW_SaldoDisponivel" />
    <sequenceFlow id="F05" sourceRef="Task_VerificarCompetitividade" targetRef="GW_PrecoCompetitivo" />
    <sequenceFlow id="F_PrecoSim" name="Sim — usar ata" sourceRef="GW_PrecoCompetitivo" targetRef="Task_PreencherOF" />
    <sequenceFlow id="F_FimNovo2" sourceRef="GW_PrecoCompetitivo" targetRef="End_NovoProcesso" />
    <sequenceFlow id="F_SaldoSim" name="Sim — dentro do limite" sourceRef="GW_SaldoDisponivel" targetRef="Task_VerificarCompetitividade" />
    <sequenceFlow id="F_FimSaldo" sourceRef="GW_SaldoDisponivel" targetRef="End_SaldoEsgotado" />
    <sequenceFlow id="F_OFSim" name="Sim" sourceRef="GW_OFValida" targetRef="Task_EnviarOFAoFornecedor" />
    <sequenceFlow id="F08" sourceRef="Task_EnviarOFAoFornecedor" targetRef="Task_AcompanharEntrega" />
    <sequenceFlow id="F_Multa" sourceRef="Task_AcionarMulta" targetRef="Task_AcompanharEntrega" />
    <sequenceFlow id="F_VoltaAcomp" sourceRef="Task_RegistrarEntregaParcial" targetRef="Task_AcompanharEntrega" />
    <sequenceFlow id="F09" sourceRef="Task_AcompanharEntrega" targetRef="GW_EntregaConforme" />
    <sequenceFlow id="F06" sourceRef="Task_PreencherOF" targetRef="Task_ValidarOF" />
    <sequenceFlow id="F_CorrigidoOF" sourceRef="Task_CorrigirOF" targetRef="Task_ValidarOF" />
    <sequenceFlow id="F07" sourceRef="Task_ValidarOF" targetRef="GW_OFValida" />
    <sequenceFlow id="F_OFNao" name="Nao — corrigir" sourceRef="GW_OFValida" targetRef="Task_CorrigirOF" />
    <sequenceFlow id="F_EntregaParcial" name="Parcial — pendencia" sourceRef="GW_EntregaConforme" targetRef="Task_RegistrarEntregaParcial" />
    <sequenceFlow id="F_EntregaSim" name="Conforme" sourceRef="GW_EntregaConforme" targetRef="Task_ReceberNotaFiscal" />
    <sequenceFlow id="F10" sourceRef="Task_ReceberNotaFiscal" targetRef="Task_VerificarDotacao" />
    <sequenceFlow id="F_TimerEnt" sourceRef="Timer_EntregaExpirada" targetRef="Task_AcionarMulta" />
    <sequenceFlow id="F_FimOk" sourceRef="Task_EncaminharPagamento" targetRef="End_ProcessoConcluido" />
    <sequenceFlow id="F_FimSuspenso" sourceRef="Task_AlertarSemDotacao" targetRef="End_Suspenso" />
    <sequenceFlow id="F11" sourceRef="Task_VerificarDotacao" targetRef="GW_DotacaoSuficiente" />
    <sequenceFlow id="F_DotSim" name="Sim" sourceRef="GW_DotacaoSuficiente" targetRef="Task_ReservarDotacao" />
    <sequenceFlow id="F_DotNao" name="Nao" sourceRef="GW_DotacaoSuficiente" targetRef="Task_AlertarSemDotacao" />
    <sequenceFlow id="F12" sourceRef="Task_ReservarDotacao" targetRef="Task_EmitirEmpenho" />
    <sequenceFlow id="F13" sourceRef="Task_EmitirEmpenho" targetRef="Task_EncaminharPagamento" />
  </process>
  <bpmndi:BPMNDiagram id="Diag_03">
    <bpmndi:BPMNPlane id="Plane_03" bpmnElement="Collab_AtaSRP">
      <bpmndi:BPMNShape id="Pool_Shape" bpmnElement="Pool_AtaSRP" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="2350" height="860" />
